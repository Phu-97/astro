---
const { data } = Astro.props;
const { Heading: HeadingConponent, Images, Button, SubTitle } = data;
const { Text } = Button;
const { Heading, Description } = HeadingConponent;
const { url, alternativeText } = Images;
import { getImageUrl } from "../../lib/getImageUrl";
---

<section
  class="bg-surface-container-low py-section-gap-lg overflow-hidden m-100"
>
  <div class="max-w-[1440px] mx-auto px-grid-margin-desktop">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
      <div class="md:col-start-2 md:col-span-4 self-center order-2 md:order-1">
        <span
          class="font-label-caps text-label-caps uppercase text-on-surface-variant block mb-6"
          >{SubTitle}</span
        >
        <h2
          class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-tertiary mb-stack-lg"
          set:html={Heading}
        />
        <p
          class="font-body-md text-body-md text-on-surface-variant mb-stack-lg leading-relaxed"
        >
          {Description.replace(/<[^>]*>/g, "")}
        </p>
        <div
          class="flex items-center gap-4 group cursor-pointer border-b border-tertiary w-fit pb-1 transition-all duration-300 hover:gap-6"
        >
          <span class="font-label-caps text-label-caps uppercase text-tertiary"
            >{Text}</span
          >
          <span class="material-symbols-outlined text-sm" data-icon="east"
            >east</span
          >
        </div>
      </div>
      <div
        class="md:col-start-7 md:col-span-5 order-1 md:order-2 mb-stack-lg md:mb-0"
      >
        <div class="grid grid-cols-2 gap-4">
          <div class="aspect-[1/1] overflow-hidden image-container">
            <img
              class="w-full h-full object-cover image-reveal"
              data-alt="A macro close-up of high-quality white Carrara marble showing intricate grey veins and a smooth honed finish. The lighting is soft and directional, highlighting the crystalline texture of the stone. This image embodies the brand's commitment to luxury materials and timeless craftsmanship in a modern architectural context."
              src={getImageUrl(Images?.[0]?.url)}
            />
          </div>
          <div
            class="aspect-[1/1] overflow-hidden image-container self-end -mb-12"
          >
            <img
              class="w-full h-full object-cover image-reveal"
              data-alt="A macro detail shot of a rich, cream-colored bouclé fabric with a soft, nubby texture. The textile is draped elegantly, creating deep shadows and highlights that emphasize its premium quality and tactile appeal. The overall aesthetic is calm, warm, and sophisticated, consistent with a minimalist luxury interior brand."
              src={getImageUrl(Images?.[1]?.url)}
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
