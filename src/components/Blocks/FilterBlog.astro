---
interface Props {
  articles: any[];
  categories: any[];
}

const { articles = [], categories = [] } = Astro.props;

// serialize để JS dùng
const articlesJson = JSON.stringify(articles);
---

<!-- Filter Bar -->
<section class="px-grid-margin-desktop max-w-[1440px] mx-auto mb-12">
  <div
    class="flex flex-wrap items-center justify-between border-b border-taupe/20 pb-6 gap-6"
  >
    <div class="flex flex-wrap gap-10">
      <!-- Category Dropdown -->
      <div class="group relative">
        <button
          class="flex items-center gap-2 font-label-caps text-label-caps uppercase tracking-widest py-2"
        >
          Category
          <span class="material-symbols-outlined text-[14px]">expand_more</span>
        </button>

        <div
          id="category-menu"
          class="absolute top-full left-0 bg-ivory shadow-xl min-w-[200px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-10 p-6 flex flex-col gap-3"
        >
          <button
            data-slug="all"
            class="filter-btn font-semibold text-body-md hover:text-taupe text-left"
          >
            All
          </button>

          {
            categories.map((cat) => (
              <button
                data-slug={cat.slug}
                class="filter-btn text-body-md hover:text-taupe text-left"
              >
                {cat.name}
              </button>
            ))
          }
        </div>
      </div>
    </div>

    <div id="product-count" class="text-body-md text-on-surface-variant italic">
      Showing {articles.length} Artifact{articles.length !== 1 ? "s" : ""}
    </div>
  </div>
</section>

<!-- Product Grid -->
<section
  id="product-grid"
  class="px-grid-margin-desktop max-w-[1440px] mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-gutter gap-y-section-gap-md"
>
  {
    articles.map((article) => (
      <div
        class="group product-card"
        data-category={article.category?.slug ?? ""}
      >
        <div class="aspect-[4/5] bg-surface-container-low overflow-hidden relative mb-6">
          {article.cover?.url && (
            <img
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              src={article.cover.url}
              alt={article.title ?? ""}
            />
          )}

          <div class="absolute inset-0 bg-charcoal/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
            <button class="bg-ivory text-charcoal px-8 py-3 uppercase">
              <a href={`/articles/${article.slug}`}>View Details</a>
            </button>
          </div>
        </div>

        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-headline-md mb-1 italic">{article.title}</h3>

            <p class="text-on-surface-variant">{article.description}</p>
          </div>

          <button class="border-b pb-0.5">Inquire</button>
        </div>
      </div>
    ))
  }
</section>

<script define:vars={{ articlesJson }}>
  const articles = JSON.parse(articlesJson);

  const grid = document.getElementById("product-grid");
  const countEl = document.getElementById("product-count");

  function buildCard(article) {
    const div = document.createElement("div");

    div.className = "group product-card";
    div.dataset.category = article.category?.slug ?? "";

    div.innerHTML = `
      <div class="aspect-[4/5] bg-surface-container-low overflow-hidden relative mb-6">
        ${
          article.cover?.url
            ? `<img
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                src="${article.cover.url}"
                alt="${article.title || ""}"
              />`
            : ""
        }

        <div class="absolute inset-0 bg-charcoal/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
           <button class="bg-ivory text-charcoal px-8 py-3 uppercase">
              <a href={`/articles/${article.slug}`}>View Details</a>
            </button>
        </div>
      </div>

      <div class="flex justify-between items-start">
        <div>
          <h3 class="font-headline-md mb-1 italic">
            ${article.title || ""}
          </h3>

          <p class="text-on-surface-variant">
            ${article.description || ""}
          </p>
        </div>

        <button class="border-b pb-0.5">
          Inquire
        </button>
      </div>
    `;

    return div;
  }

  function setActiveFilter(slug) {
    document.querySelectorAll(".filter-btn").forEach((btn) => {
      btn.classList.toggle("font-semibold", btn.dataset.slug === slug);
    });
  }

  function renderArticles(filteredArticles) {
    const fragment = document.createDocumentFragment();

    filteredArticles.forEach((article) => {
      fragment.appendChild(buildCard(article));
    });

    grid.replaceChildren(fragment);

    const n = filteredArticles.length;

    countEl.textContent = "Showing " + n + " Artifact" + (n !== 1 ? "s" : "");
  }

  document.querySelectorAll(".filter-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const slug = btn.dataset.slug;

      setActiveFilter(slug);

      const filtered =
        slug === "all"
          ? articles
          : articles.filter((a) => a.category?.slug === slug);

      renderArticles(filtered);
    });
  });
</script>
