---
const { data } = Astro.props;
const { Heading, SubTitle, Description, Image1, Image2, Image, HeadingImage } =
  data;
const { url, alternativeText } = Image1;
---

<section class="mb-section-gap-lg px-grid-margin-desktop">
  <div
    class="max-w-[1440px] mx-auto grid grid-cols-1 md:grid-cols-4 gap-gutter h-auto md:h-[600px]"
  >
    <div class="md:col-span-1 h-full flex flex-col gap-gutter">
      <div class="flex-1 bg-taupe/10 p-stack-lg flex flex-col justify-end">
        <span class="font-label-caps text-label-caps text-tertiary mb-2"
          >{Heading}</span
        >
        <p class="font-body-md text-sm text-on-surface-variant italic">
          {SubTitle}
        </p>
      </div>
      <div class="flex-1 overflow-hidden image-container">
        <img
          class="w-full h-full object-cover image-reveal"
          data-alt={Image1?.alternativeText}
          src={`${import.meta.env.PUBLIC_STRAPI_URL}${Image1?.url}`}
        />
      </div>
    </div>
    <div class="md:col-span-2 overflow-hidden image-container relative">
      <img
        class="w-full h-full object-cover image-reveal"
        data-alt={Image2?.alternativeText}
        src={`${import.meta.env.PUBLIC_STRAPI_URL}${Image2?.url}`}
      />
      <div class="absolute bottom-10 left-10 text-ivory">
        <h3 class="font-display-xl text-headline-lg">{HeadingImage}</h3>
      </div>
    </div>
    <div class="md:col-span-1 flex flex-col gap-gutter">
      <div class="flex-[2] overflow-hidden image-container">
        <img
          class="w-full h-full object-cover image-reveal"
          data-alt={Image?.alternativeText}
          src={`${import.meta.env.PUBLIC_STRAPI_URL}${Image?.url}`}
        />
      </div>
      <div
        class="flex-1 border border-outline-variant/30 flex items-center justify-center p-stack-lg"
      >
        <p class="font-body-md text-center text-on-surface-variant">
          {Description?.[0]?.children?.[0]?.text}
        </p>
      </div>
    </div>
  </div>
</section>
