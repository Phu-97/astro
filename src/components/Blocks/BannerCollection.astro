---
const { data } = Astro.props;
const { Heading: HeadingConponent } = data;

const { Heading, Description, SubText } = HeadingConponent;
---

<section
  class="px-grid-margin-desktop max-w-[1440px] mx-auto mb-section-gap-md md:py-32"
>
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
    <div class="max-w-2xl">
      <span
        class="font-label-caps text-label-caps uppercase text-on-surface-variant block mb-4"
      >
        {SubText}
      </span>
      <h1 class="font-display-xl text-display-xl-mobile lg:text-display-xl">
        {Heading}
      </h1>
    </div>
    <p class="font-body-lg text-body-lg text-on-surface-variant max-w-sm mb-2">
      {Description.replace(/<[^>]*>/g, "")}
    </p>
  </div>
</section>
