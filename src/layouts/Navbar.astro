---
const { logo, menu, button, currentPath = "/" } = Astro.props;
---

<div class="flex items-center gap-stack-lg">
  <a
    class="font-display-xl text-headline-md tracking-tighter text-tertiary"
    href={logo?.Link ?? "/"}
  >
    {logo?.Logo ?? "BlissHaven"}
  </a>
</div>

<!-- Desktop menu -->
<div class="sm:hidden lg:flex items-center gap-10">
  {
    menu.map((item: any) => {
      const href = item.Link ?? item.URL ?? item.link ?? "#";
      const isActive =
        href === "/" ? currentPath === "/" : currentPath.startsWith(href);

      return (
        <a
          href={href}
          class={`font-body-md text-body-md tracking-widest uppercase text-on-surface-variant hover:text-tertiary transition-colors duration-500 ${isActive ? "active" : "menu"}`}
        >
          {item.Text}
        </a>
      );
    })
  }
</div>

<!-- Right section -->
<div class="flex items-center gap-stack-md">
  {
    button.map((btn: any) => (
      <a
        href={btn.Link ?? "#"}
        class="p-2 hover:opacity-70 transition-opacity duration-500"
      >
        <span class="material-symbols-outlined">
          {btn.Text === "Cart" ? "shopping_bag" : "person"}
        </span>
      </a>
    ))
  }

  <!-- Hamburger -->
  <button id="menu-toggle" class="lg:hidden p-2">
    <span class="material-symbols-outlined">menu</span>
  </button>
</div>
