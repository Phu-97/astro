---
import Layout from "../layouts/Layout.astro";
import HeroBanner from "../components/Blocks/HeroBanner.astro";
import AboutSection from "../components/Blocks/AboutSection.astro";
import FeaturedCurations from "../components/Blocks/FeaturedCurations.astro";
import Slogent from "../components/Blocks/Slogent.astro";
import Gallery from "../components/Blocks/Gallery.astro";
import CTA from "../components/Blocks/CTA.astro";
import { fetchAPI } from "../lib/strapi";
import { homeQuery } from "../lib/queries/home";
import "../styles/collection.css";

const data = await fetchAPI("home", homeQuery);
const blocks = data.data.Blocks;

const seoBlock = blocks.find((b) => b.__component === "shared.seo");

const componentMap = {
  "block.hero-banner": HeroBanner,
  "block.about-section": AboutSection,
  "block.featured-curations": FeaturedCurations,
  "block.slogent": Slogent,
  "block.gallery": Gallery,
  "block.cta": CTA,
};

const renderableBlocks = blocks.filter((b) => b.__component !== "shared.seo");
---

<Layout
  title={seoBlock?.metaTitle ?? ""}
  description={seoBlock?.metaDescription ?? ""}
>
  {
    renderableBlocks.map((block) => {
      const Component = componentMap[block.__component];
      return Component ? <Component data={block} /> : null;
    })
  }
</Layout>
