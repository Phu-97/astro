---
import Layout from "../layouts/Layout.astro";
import FilterBlog from "../components/Blocks/FilterBlog.astro";
import BannerCollection from "../components/Blocks/BannerCollection.astro";
import Materiality from "../components/Blocks/Materiality.astro";
import OutstandingArticle from "../components/Blocks/OutstandingArticle.astro";
import ContactForm from "../components/Blocks/ContactForm.astro";
import { fetchAPI } from "../lib/strapi";
import {
  getArticlesQuery,
  getCollectionQuery,
} from "../lib/queries/collection";
import "../styles/collection.css";

const category = Astro.url.searchParams.get("category");

const [articlesData, collectionData] = await Promise.all([
  fetchAPI("articles", getArticlesQuery(category)),
  fetchAPI("collection", getCollectionQuery()),
]);

const articles = articlesData.data ?? [];
const blocks = collectionData.data?.Blocks ?? [];

const getBlock = (type: string) => blocks.find((b) => b.__component === type);
const bannerStory = getBlock("block.banner-story");
const materiality = getBlock("block.about-section");
const contactForm = getBlock("block.contact-form");
const seoBlock = getBlock("shared.seo");
const categories = [
  ...new Map(
    articles.filter((a) => a.category).map((a) => [a.category.id, a.category]),
  ).values(),
];
---

<Layout
  title={seoBlock?.metaTitle ?? ""}
  description={seoBlock?.metaDescription ?? ""}
>
  {bannerStory && <BannerCollection data={bannerStory} />}

  <FilterBlog articles={articles} categories={categories} client:load />

  {materiality && <Materiality data={materiality} />}

  <OutstandingArticle articles={articles} />

  {contactForm && <ContactForm data={contactForm} />}
</Layout>
